# 複製為 .env 後填入實際值；.env 不進 git（SPEC §7）
DICTATION_TOKEN=change-me
POLISH_PROVIDER=gemini
GEMINI_API_KEY=
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
# 容器內連 host 的 Ollama 用 http://host.docker.internal:11434（compose 需加 extra_hosts）
# 或 host 的 docker0 IP（通常 http://172.17.0.1:11434）
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_MODEL=qwen2.5:7b
STT_MODEL=small
TZ=Asia/Taipei

# 網路綁定（SPEC §2.4）：預設 127.0.0.1 僅本機；
# 接上 Tailscale 後改成 VPS 的 tailnet IP（tailscale ip -4），不開公網 port
BIND_IP=127.0.0.1
HOST_PORT=8010
